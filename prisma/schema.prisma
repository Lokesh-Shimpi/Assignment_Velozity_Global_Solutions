generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MEMBER
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  users     User[]
  apiKeys   ApiKey[]
  emailLogs EmailDeliveryLog[]
  auditLogs AuditLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  email     String   @unique
  role      Role     @default(MEMBER)
  apiKeys   ApiKey[] @relation("UserToApiKey")
  auditLogs AuditLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  hashedKey  String    @unique
  expiresAt  DateTime?
  createdById String    @db.Uuid
  createdBy  User      @relation("UserToApiKey", fields: [createdById], references: [id])
  auditLogs  AuditLog[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model EmailDeliveryLog {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String?     @db.Uuid
  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  recipient    String
  templateUsed String
  status       EmailStatus @default(PENDING)
  attemptCount Int         @default(0)
  timestamp    DateTime    @default(now())
  errorMsg     String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  userId        String?  @db.Uuid
  user          User?    @relation(fields: [userId], references: [id])
  apiKeyId      String?  @db.Uuid
  apiKey        ApiKey?  @relation(fields: [apiKeyId], references: [id])
  action        String
  resourceType  String
  resourceId    String
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  timestamp     DateTime @default(now())
  previousHash  String?
  hash          String

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([timestamp])
}
